# Open Thermal AI — frontend (Vite). Copy to `.env.local` for local live Copilot.

# Option A — same-origin `/v1` via Vite proxy (recommended for local)
# Start proxy first: npm run server
VITE_AI_USE_PROXY=true

# Option B — absolute proxy URL (also use for production build pointing at Aliyun API)
# VITE_AI_API_BASE=http://127.0.0.1:8787
# VITE_AI_API_BASE=https://api.jingyanrong.com

# Leave both unset → Phase 1 mock (no network LLM). Safe default for GitHub Pages.
