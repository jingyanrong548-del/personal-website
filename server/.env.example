# Open Thermal AI proxy — copy to server/.env and fill in values.
# Never commit real keys. Static frontend must NOT receive LLM_API_KEY.

PORT=8787

# Comma-separated browser origins allowed to call the API.
# Local Vite + production site examples:
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,https://www.jingyanrong.com,https://jingyanrong.com

RATE_LIMIT_PER_MIN=30

# --- LLM (OpenAI-compatible) ---
# Swap provider later by changing BASE_URL + MODEL + KEY only.

# Example A — Groq (often has a free tier; check current limits)
LLM_PROVIDER=groq
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile

# Example B — OpenRouter free models (uncomment & set key)
# LLM_PROVIDER=openrouter
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=
# LLM_MODEL=meta-llama/llama-3.2-3b-instruct:free

# Example C — DeepSeek
# LLM_PROVIDER=deepseek
# LLM_BASE_URL=https://api.deepseek.com
# LLM_API_KEY=
# LLM_MODEL=deepseek-chat

# Example D — Local Ollama
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://127.0.0.1:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.2

LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1200
LLM_TIMEOUT_MS=60000

# Set to false to keep /v1/thermal-engineer/analyze pure rules (no LLM polish)
LLM_ENHANCE_ANALYZE=true
