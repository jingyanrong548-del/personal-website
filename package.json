{
  "name": "jing-yanrong",
  "version": "3.0.0",
  "description": "Personal homepage for Jing Yanrong (荆炎荣)",
  "type": "module",
  "scripts": {
    "dev": "node scripts/build-content.mjs && vite",
    "prebuild": "node scripts/build-content.mjs",
    "build": "vite build && node scripts/remove-crossorigin.js",
    "generate:diagrams": "python3 scripts/generate-knowledge-cycles-diagrams.py && python3 scripts/generate-knowledge-extreme-cold-charts.py && python3 scripts/generate-hthp-config-overlays.py && python3 scripts/overlay-knowledge-3d-legends.py",
    "preview": "vite preview",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major",
    "version": "node scripts/bump-version.js patch"
  },
  "keywords": [
    "jing-yanrong",
    "vite"
  ],
  "author": "Thomas Jing",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "@vercel/analytics": "^1.6.1",
    "lucide": "^0.562.0"
  }
}
